{
  "name": "ifrs16-app",
  "private": true,
  "workspaces": ["lib", "server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=lib && npm run build --workspace=server && npm run build --workspace=client",
    "test": "npm run test --workspace=lib"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "20.x"
  }
}
